rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Публичное чтение нужно для входа по username (email резолвится ДО авторизации
      // в FirebaseAuth) и для профилей пользователей. Секретных полей (пароль и т.п.)
      // в этой коллекции нет — пароли хранит сам Firebase Auth, а не Firestore.
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /usernames/{username} {
      // Хранит только { uid }, публичное чтение необходимо, чтобы найти email
      // по username при входе (до того, как пользователь аутентифицирован).
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /chats/{chatId} {
      allow read, write: if request.auth != null && request.auth.uid in resource.data.participantIds;
      allow create: if request.auth != null;
      match /messages/{messageId} {
        allow read, create: if request.auth != null;
        allow update: if request.auth != null;
        allow delete: if request.auth != null;
      }
    }
  }
}
